{
  "name": "clawshell",
  "version": "1.0.2",
  "description": "虾壳 ClawShell — 面向普通用户的 AI 助手桌面客户端",
  "main": "electron/main.js",
  "author": "ClawShell",
  "license": "AGPL-3.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "electron:build": "vite build && electron-builder",
    "build:win": "npm run electron:build -- --win",
    "build:mac": "npm run electron:build -- --mac",
    "build:linux": "npm run electron:build -- --linux"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1",
    "pinia": "^3.0",
    "vue": "^3.5",
    "vue-router": "^4.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2",
    "concurrently": "^9.0",
    "electron": "^35.0",
    "electron-builder": "^26.0",
    "vite": "^6.0",
    "wait-on": "^8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
